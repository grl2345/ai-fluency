NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Publishable key — safe for browser; used by login + user-facing APIs (verify/cancel subscription)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Service role — server-only, never expose to client.
# Required only for PayPal webhook (no logged-in user). Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── PayPal ─────────────────────────────────────────────────────────────────
# 1. 登录 https://developer.paypal.com → My Apps & Credentials → Create App
# 2. 将 Sandbox/Live 的 Client ID 和 Secret 填入下方
# 3. 在 PayPal Dashboard → Subscriptions → Plans 创建订阅计划，获取 Plan ID
# 4. 在 PayPal Dashboard → Webhooks 添加 webhook URL：
#    https://your-domain.com/api/paypal/webhook
#    选择事件：BILLING.SUBSCRIPTION.*, PAYMENT.SALE.COMPLETED

NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox                          # 上线后改为 live

# PayPal Subscription Plan IDs（在 PayPal Dashboard 创建后填入）
NEXT_PUBLIC_PAYPAL_PLAN_ID_PRO=P-your-pro-plan-id
NEXT_PUBLIC_PAYPAL_PLAN_ID_TEAM=P-your-team-plan-id

# ── Supabase SQL ───────────────────────────────────────────────────────────
# 在 Supabase Dashboard → SQL Editor 执行 scripts/supabase-subscriptions.sql

# 本地开发时，在 Supabase Dashboard → Authentication → URL Configuration 添加：
# Site URL: http://localhost:4200
# Redirect URLs: http://localhost:4200/auth/callback

# OAuth 在 Supabase Dashboard → Authentication → Providers 配置：
# - Google：填入 Google Cloud OAuth Client ID / Secret
# - GitHub：填入 GitHub OAuth App Client ID / Secret
#
# Google Cloud Console 中 Authorized redirect URI 使用 Supabase 提供的：
# https://<project-ref>.supabase.co/auth/v1/callback
#
# GitHub OAuth App 的 Authorization callback URL 同样使用：
# https://<project-ref>.supabase.co/auth/v1/callback
