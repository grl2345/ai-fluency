NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# 本地开发时，在 Supabase Dashboard → Authentication → URL Configuration 添加：
# Site URL: http://localhost:4200
# Redirect URLs: http://localhost:4200/auth/callback

# OAuth 在 Supabase Dashboard → Authentication → Providers 配置：
# - Google：填入 Google Cloud OAuth Client ID / Secret
# - GitHub：填入 GitHub OAuth App Client ID / Secret
#
# Google Cloud Console 中 Authorized redirect URI 使用 Supabase 提供的：
# https://<project-ref>.supabase.co/auth/v1/callback
#
# GitHub OAuth App 的 Authorization callback URL 同样使用：
# https://<project-ref>.supabase.co/auth/v1/callback
